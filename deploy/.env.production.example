# Production environment template
# Copy to .env.production and fill in real values — NEVER commit this file with secrets

# Application
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql+asyncpg://taskflow:CHANGE_ME@db:5432/taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=taskflow

# Redis
REDIS_URL=redis://redis:6379/0

# Deployment (used by CD pipeline)
DEPLOY_HOST=your-server-ip
DEPLOY_USER=deploy
# DEPLOY_SSH_KEY is set as a GitHub secret
